<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Brand style circular frame (moldura redonda) -->
    <!-- Rich dark grey base for high logo contrast -->
    <path
        android:pathData="M 54,17 a 37,37 0 1,0 0,74 a 37,37 0 1,0 0,-74 Z"
        android:fillColor="#151417" />

    <!-- Highly contrasting metallic gold & crimson gradient ring -->
    <path
        android:pathData="M 54,17 a 37,37 0 1,0 0,74 a 37,37 0 1,0 0,-74 Z"
        android:strokeWidth="2.0">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:type="linear"
                android:startX="17"
                android:startY="17"
                android:endX="91"
                android:endY="91">
                <item android:offset="0.0" android:color="#FFFFD700" /> <!-- Shining Gold/Amarelo Ouro -->
                <item android:offset="0.4" android:color="#FFFF3B30" /> <!-- Vivid Red -->
                <item android:offset="0.6" android:color="#FFFFFFFF" /> <!-- Silver Highlight -->
                <item android:offset="1.0" android:color="#FFB30404" /> <!-- Dark Red -->
            </gradient>
        </aapt:attr>
    </path>

    <!-- Up-scaled and perfectly centered MK21 Logo group inside the circular frame -->
    <group
        android:pivotX="53"
        android:pivotY="52.5"
        android:scaleX="0.74"
        android:scaleY="0.74"
        android:translateX="1"
        android:translateY="1.5">

        <!-- "M" metallic-silver gradient path -->
        <path
            android:pathData="M 14,68 L 22,36 L 27.5,36 L 26,51 L 32,36 L 37.5,36 L 29.5,68 L 24.5,68 L 25,54 L 19,68 Z">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:type="linear"
                    android:startX="14"
                    android:startY="36"
                    android:endX="14"
                    android:endY="68">
                    <item android:offset="0.0" android:color="#FFFFFF" />
                    <item android:offset="0.35" android:color="#EDEDED" />
                    <item android:offset="0.7" android:color="#9E9E9E" />
                    <item android:offset="1.0" android:color="#535353" />
                </gradient>
            </aapt:attr>
        </path>

        <!-- "K Stick" metallic-silver gradient path -->
        <path
            android:pathData="M 34,68 L 42,36 L 47,36 L 39,68 Z">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:type="linear"
                    android:startX="34"
                    android:startY="36"
                    android:endX="34"
                    android:endY="68">
                    <item android:offset="0.0" android:color="#FFFFFF" />
                    <item android:offset="0.35" android:color="#EDEDED" />
                    <item android:offset="0.7" android:color="#9E9E9E" />
                    <item android:offset="1.0" android:color="#535353" />
                </gradient>
            </aapt:attr>
        </path>

        <!-- "K Arms" metallic-silver gradient path -->
        <path
            android:pathData="M 42,53 L 55,36 L 61,36 L 45,55 L 56,68 L 50,68 L 41,57 Z">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:type="linear"
                    android:startX="41"
                    android:startY="36"
                    android:endX="41"
                    android:endY="68">
                    <item android:offset="0.0" android:color="#FFFFFF" />
                    <item android:offset="0.35" android:color="#EDEDED" />
                    <item android:offset="0.7" android:color="#9E9E9E" />
                    <item android:offset="1.0" android:color="#535353" />
                </gradient>
            </aapt:attr>
        </path>

        <!-- "2" neon-red gradient path -->
        <path
            android:pathData="M 66,43 C 68,36, 81,36, 79,45 C 78,52, 67,56, 65,63 L 76,63 L 74,69 L 61,69 L 62,59 C 66,53, 71,50, 72,45 C 72,41, 68,41, 67,43 Z">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:type="linear"
                    android:startX="66"
                    android:startY="36"
                    android:endX="66"
                    android:endY="69">
                    <item android:offset="0.0" android:color="#FF5252" />
                    <item android:offset="0.5" android:color="#FF1E1E" />
                    <item android:offset="1.0" android:color="#B30404" />
                </gradient>
            </aapt:attr>
        </path>

        <!-- "1" neon-red gradient path -->
        <path
            android:pathData="M 81,45 L 87,40 L 92,40 L 84,69 L 79,69 L 85,45 Z">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:type="linear"
                    android:startX="81"
                    android:startY="40"
                    android:endX="81"
                    android:endY="69">
                    <item android:offset="0.0" android:color="#FF5252" />
                    <item android:offset="0.5" android:color="#FF1E1E" />
                    <item android:offset="1.0" android:color="#B30404" />
                </gradient>
            </aapt:attr>
        </path>

        <!-- Glowing central horizontal horizon line -->
        <path
            android:pathData="M 18,72.5 L 90,72.5"
            android:strokeWidth="1.2">
            <aapt:attr name="android:strokeColor">
                <gradient
                    android:type="linear"
                    android:startX="18"
                    android:startY="72.5"
                    android:endX="90"
                    android:endY="72.5">
                    <item android:offset="0.0" android:color="#00FF1E1E" />
                    <item android:offset="0.3" android:color="#FFFF1E1E" />
                    <item android:offset="0.5" android:color="#FFFFFFFF" />
                    <item android:offset="0.7" android:color="#FFFF1E1E" />
                    <item android:offset="1.0" android:color="#00FF1E1E" />
                </gradient>
            </aapt:attr>
        </path>

        <!-- Left flared red wing/flare -->
        <path
            android:pathData="M 20,78 L 44,78"
            android:strokeWidth="1.0">
            <aapt:attr name="android:strokeColor">
                <gradient
                    android:type="linear"
                    android:startX="20"
                    android:startY="78"
                    android:endX="44"
                    android:endY="78">
                    <item android:offset="0.0" android:color="#00FF1E1E" />
                    <item android:offset="1.0" android:color="#FFFF1E1E" />
                </gradient>
            </aapt:attr>
        </path>

        <!-- Right flared red wing/flare -->
        <path
            android:pathData="M 64,78 L 88,78"
            android:strokeWidth="1.0">
            <aapt:attr name="android:strokeColor">
                <gradient
                    android:type="linear"
                    android:startX="64"
                    android:startY="78"
                    android:endX="88"
                    android:endY="78">
                    <item android:offset="0.0" android:color="#FFFF1E1E" />
                    <item android:offset="1.0" android:color="#00FF1E1E" />
                </gradient>
            </aapt:attr>
        </path>
    </group>
</vector>
